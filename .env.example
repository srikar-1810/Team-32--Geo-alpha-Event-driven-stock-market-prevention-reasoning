# ──────────────────────────────────────────────
# GeoMarketGPT — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Application
APP_NAME=GeoMarketGPT
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=DEBUG

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/geomarketgpt
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ChromaDB
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_EVENTS=geopol_events
CHROMA_COLLECTION_SENTIMENT=sentiment_data
CHROMA_COLLECTION_MARKETS=market_data
CHROMA_COLLECTION_REPORTS=reports
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_EMBEDDING_CACHE_SIZE=10000
CHROMA_EMBEDDING_CACHE_PATH=data/cache/embeddings.json

# Historical RAG
CHROMA_COLLECTION_HISTORICAL=historical_events
HISTORICAL_RAG_TOP_K_DEFAULT=10
HISTORICAL_RAG_MAX_CONTEXT_CHARS=8000
HISTORICAL_RAG_MIN_SIMILARITY=0.3
HISTORICAL_RAG_CONFIDENCE_THRESHOLD=0.4

# LLM Provider
# LLM_PROVIDER=xai
# XAI_API_KEY=<your-xai-api-key>
# XAI_MODEL=grok-2-latest
# XAI_BASE_URL=https://api.x.ai/v1

# Autonomous Intelligence Briefs (auto-generated every 20 min)
REPORT_AUTO_GENERATE_INTERVAL=1200
REPORT_KEEP_HOURS=72
REPORT_OUTPUT_DIR=data/reports
REPORT_MAX_EVENTS_PER_BRIEF=15
REPORT_MAX_SECTORS_PER_BRIEF=10

# GDELT API
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
GDELT_TIMEOUT=30
GDELT_MAX_RETRIES=3
GDELT_POLL_INTERVAL=1200
GDELT_QUERIES=conflict,war,sanctions,election,crisis,protest,military,trade,terrorism,diplomacy,oil,inflation,interest rates,central bank,tariff,treaty,summit,weapon,nuclear,cyberattack

# Reddit API
REDDIT_CLIENT_ID=<your-reddit-client-id>
REDDIT_CLIENT_SECRET=<your-reddit-client-secret>
REDDIT_USER_AGENT=GeoMarketGPT/0.1.0
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing,geopolitics,worldnews,economics,StockMarket,options,MarketSentiment,trade
REDDIT_FETCH_LIMIT=100
REDDIT_POLL_INTERVAL=300
REDDIT_CONCURRENCY=3
REDDIT_SORT_STRATEGY=balanced
REDDIT_MAX_POST_AGE_HOURS=24

# Tiingo Stock API
TIINGO_API_TOKEN=<your-tiingo-api-key>
TIINGO_BASE_URL=https://api.tiingo.com
TIINGO_TIMEOUT=30
TIINGO_MAX_RETRIES=3
TIINGO_RATE_LIMIT=500
TIINGO_SECTOR_ETFS=SPY,QQQ,IWM,EEM,XLF,XLE,XLK,XLV,XLI,XLB,XLU,XLY,XLP,XLRE,XLC,VNQ,GLD,SLV,USO,TLT,SHY,AGG,LQD,HYG

# Yahoo Finance (fallback when Tiingo unavailable)
YAHOO_ENABLE_FALLBACK=true
YAHOO_TIMEOUT=30

# Ingestion
INGESTION_CACHE_TTL_HOURS=24
INGESTION_MARKET_HOURS_ONLY=true

# OpenAI / LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-openai-or-gemini-api-key>
OPENAI_MODEL=gemini-3.1-flash-lite
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_EMBEDDING_MODEL=text-embedding-004
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# LangSmith / LangChain Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=<your-langchain-api-key>
LANGCHAIN_PROJECT=GeoMarketGPT

# Celery / Task Queue
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]

# Streamlit Frontend
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
MOCK_MODE=false
API_BASE_URL=http://api:8000

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090
ENABLE_METRICS=true
